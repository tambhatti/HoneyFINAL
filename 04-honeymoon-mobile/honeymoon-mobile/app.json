{
  "expo": {
    "name": "Honeymoon",
    "slug": "honeymoon-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.honeymoon.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Honeymoon to access your camera to upload profile photos and service images.",
        "NSPhotoLibraryUsageDescription": "Allow Honeymoon to access your photos to upload profile photos and service images.",
        "NSLocationWhenInUseUsageDescription": "Allow Honeymoon to access your location to find nearby vendors.",
        "NSFaceIDUsageDescription": "Allow Honeymoon to use Face ID for secure login."
      }
    },
    "android": {
      "package": "com.honeymoon.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#174a37"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "scheme": "honeymoon",
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#174a37",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "apiUrl": "http://localhost:5000/api/v1",
      "eas": {
        "projectId": "your-eas-project-id"
      }
    },
    "intentFilters": [
      {
        "action": "VIEW",
        "autoVerify": true,
        "data": [
          {
            "scheme": "honeymoon",
            "host": "auth",
            "pathPrefix": "/callback"
          }
        ],
        "category": [
          "BROWSABLE",
          "DEFAULT"
        ]
      }
    ]
  }
}